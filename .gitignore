# Unity .gitignore
# This file is placed at the Git repository root.
# It also works when the Unity project is inside a subfolder, e.g. GameJam3D22/

# Unity generated folders
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
[Mm]emoryCaptures/
[Rr]ecordings/

# Unity temporary files
.utmp/
*.log
sysinfo.txt

# Asset Store Tools
**/[Aa]ssets/AssetStoreTools*

# JetBrains Rider plugin
**/[Aa]ssets/Plugins/Editor/JetBrains*

# Visual Studio / Rider / IDE files
.vs/
.gradle/
ExportedObj/
.consulo/

*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity generated meta files for ignored files
*.pidb.meta
*.pdb.meta
*.mdb.meta
*.blend1
*.blend1.meta

# Builds / packages
*.apk
*.aab
*.app
*.exe
*.dmg
*.unitypackage
*.unitypackage.meta

# Crashlytics
crashlytics-build.properties

# Addressables build data
**/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# Temporary auto-generated Android Addressables assets
**/[Aa]ssets/[Ss]treamingAssets/aa.meta
**/[Aa]ssets/[Ss]treamingAssets/aa/*

# OS generated files
.DS_Store
Thumbs.db
desktop.ini